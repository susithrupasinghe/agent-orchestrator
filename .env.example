# Copy this file to .env and fill in values before running docker-compose up

# LM Studio local endpoint (default works if LM Studio runs on host port 1234)
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# Model name shown in LM Studio "Local Server" tab (use the exact identifier)
LM_STUDIO_MODEL=local-model

# Fallback GitHub repo URL used when the user doesn't supply one
GITHUB_REPO_URL=https://github.com/torvalds/linux

# ClickUp integration
CLICKUP_API_KEY=pk_your_api_key_here
CLICKUP_LIST_ID=901817612256

# Redis (usually no need to change)
REDIS_HOST=redis
REDIS_PORT=6379
